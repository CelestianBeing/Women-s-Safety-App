# Copy this file to .env and fill in your values.
# Never commit .env to version control.

FLASK_ENV=production
SECRET_KEY=generate-a-random-256-bit-string-here

# Database (leave blank for SQLite)
DATABASE_URL=

# OSM area to model (must be a valid Nominatim place name)
PLACE_NAME=Connaught Place, New Delhi, India

# Email (for SOS alerts)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@safetyroute.app

PORT=5000
LOG_LEVEL=INFO
